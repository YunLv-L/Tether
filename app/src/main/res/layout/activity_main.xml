<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0F172A">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔗 Tether"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#3B82F6"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnDiscover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="刷新扫描"
        android:backgroundTint="#3B82F6"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- 手动输入 IP 区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etManualIP"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入 IP 地址"
            android:textColorHint="#94A3B8"
            android:textColor="#FFFFFF"
            android:background="@android:drawable/editbox_background"
            android:padding="8dp"
            android:inputType="phone"
            android:text="192.168.10.10"/>

        <Button
            android:id="@+id/btnManualConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接"
            android:backgroundTint="#3B82F6"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="发现的设备:"
        android:textSize="14sp"
        android:textColor="#94A3B8"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/listViewDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E293B"
        android:divider="#334155"
        android:dividerHeight="1dp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSendLock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="锁定"
            android:backgroundTint="#F59E0B"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnSendSleep"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="睡眠"
            android:backgroundTint="#8B5CF6"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnSendShutdown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="关机"
            android:backgroundTint="#EF4444"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

</LinearLayout>