<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 浅色主题自定义颜色 -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="#F5F7FA"/>
    <SolidColorBrush x:Key="SecondaryBackground" Color="#EDF0F5"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="#E8ECF1"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#5A5A7A"/>
    <SolidColorBrush x:Key="Divider" Color="#D0D5DD"/>
    <SolidColorBrush x:Key="HoverBackground" Color="#E8EEF8"/>
    <SolidColorBrush x:Key="AccentColor" Color="#4A9EFF"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#4CAF50"/>
    <SolidColorBrush x:Key="ErrorColor" Color="#EF5350"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFC107"/>

    <!-- 控件样式 -->
    <Style TargetType="Border" x:Key="CardBorder">
        <Setter Property="Background" Value="{StaticResource CardBackground}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BorderBrush" Value="{StaticResource Divider}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBlock" x:Key="TitleText">
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="SubtitleText">
        <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

</ResourceDictionary>